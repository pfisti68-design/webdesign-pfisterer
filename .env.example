# Email Configuration
# Wähle eine der folgenden Optionen und fülle die Credentials aus

# Option 1: Gmail (App Password erforderlich)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=deine-email@gmail.com
# SMTP_PASS=dein-app-password
# SMTP_FROM="Webdesign-Pfisterer <deine-email@gmail.com>"

# Option 2: Hostinger SMTP
# SMTP_HOST=mail.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=deine-email@webdesign-pfisterer.de
# SMTP_PASS=dein-password
# SMTP_FROM="Webdesign-Pfisterer <deine-email@webdesign-pfisterer.de>"

# Option 3: SendGrid (kostenlos bis 100 Emails/Tag)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM=noreply@webdesign-pfisterer.de

# Kontakt Email
CONTACT_EMAIL=pfisti68@gmail.com
